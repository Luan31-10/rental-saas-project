generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum PlanType {
  FREE      // Gói Mầm non (Tối đa 10 phòng)
  PRO       // Gói Tiêu chuẩn 299k
  ENTERPRISE // Gói Cá mập
}

// 1. BẢNG NGƯỜI DÙNG
model User {
  id                 String     @id @default(auto()) @map("_id") @db.ObjectId
  email              String     @unique
  password           String?    
  name               String?
  phone              String?  
  avatar             String?
  address            String?
  role               String     @default("TENANT") // OWNER hoặc TENANT
  createdAt          DateTime   @default(now())
  twoFactorSecret    String?    
  isTwoFactorEnabled Boolean    @default(false)
  upgradeOrderCode   Int?       
  pendingPlan        String?
  resetToken         String?    
  resetTokenExpires  DateTime?

  bankId             String?    @default("TCB")
  bankAccount        String?
  bankAccountName    String?
  
  plan               PlanType   @default(FREE)
  planExpiryDate     DateTime?  
  
  properties Property[] 
  tenantProfiles Tenant[]
}

// 2. BẢNG KHU TRỌ / TÒA NHÀ
model Property {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  name      String   
  address   String   
  createdAt DateTime @default(now())

  
  baseElectricityPrice Float @default(3500)
  baseWaterPrice       Float @default(15000)
  defaultRoomPrice     Float @default(0)

  ownerId   String   @db.ObjectId
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  rooms      Room[]   
}

// 3. BẢNG PHÒNG TRỌ
model Room {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  roomNumber String   
  price      Float    
  area       Float?   
  deposit    Float?   
  status     String   @default("AVAILABLE") 
  createdAt  DateTime @default(now())
  
  tenants    Tenant[]
  invoices   Invoice[]
  issues     Issue[]

  propertyId String   @db.ObjectId
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// 4. BẢNG KHÁCH THUÊ
model Tenant {
  id         String    @id @default(auto()) @map("_id") @db.ObjectId
  name       String
  phone      String
  email      String?
  idCard     String?   
  deposit    Float     @default(0) 
  issues     Issue[]
  
  startDate  DateTime  @default(now()) 
  endDate    DateTime? 
  status     String    @default("ACTIVE") 
  
  roomId     String    @db.ObjectId
  room       Room      @relation(fields: [roomId], references: [id], onDelete: Cascade)

  userAccountId String? @db.ObjectId
  userAccount   User?   @relation(fields: [userAccountId], references: [id])

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

// 5. BẢNG HÓA ĐƠN
model Invoice {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float    
  electricity Float    
  water       Float    
  status      String   @default("PENDING") 
  month       Int      
  year        Int      
  createdAt   DateTime @default(now())
  orderCode   Int?     @unique

  roomId      String   @db.ObjectId
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
}

// 6. BẢNG SỰ CỐ
model Issue {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String   
  description String?  
  status      String   @default("PENDING") 
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  roomId      String   @db.ObjectId
  room        Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)

  tenantId    String   @db.ObjectId
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  comments    IssueComment[]
}

model IssueComment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String   
  sender    String   
  createdAt DateTime @default(now())
  
  issueId   String   @db.ObjectId
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}